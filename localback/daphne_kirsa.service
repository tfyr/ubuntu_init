[Unit]
Description=Daphne kirsa backend
After=network.target
After=mysql.service
Wants=mysql.service
Requires=mysql.service

[Service]
User=pos
Group=pos
WorkingDirectory=/home/pos/kirsa
Environment="PYTHONPATH=/home/pos/kirsa-plugin:/home/pos/kirsa-kkm"
ExecStartPre=/bin/rm -f kirsa.sock kirsa.sock.lock
ExecStart=/home/pos/kirsa/env/bin/daphne -u kirsa.sock kirsa.asgi:application
Restart=always


[Install]
WantedBy=multi-user.target
